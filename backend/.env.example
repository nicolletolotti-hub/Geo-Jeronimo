PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000,https://geojeronimo-v4.vercel.app

# JWT Secret (gerar um forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-secret-key-change-this-in-production

# OpenWeather API
OPENWEATHER_API_KEY=your-openweather-api-key

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geojeronimo
DB_USER=postgres
DB_PASSWORD=your-database-password

# ANA Telemetria API
ANA_STATION_CODE=24184000
