# Variáveis de Ambiente para o Backend

# URL de conexão do Banco de Dados PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/geojeronimo"

# Segredo para a criação dos tokens JWT
JWT_SECRET="SEU_SEGREDO_SUPER_SECRETO_AQUI"

# Segredo para o refresh token
REFRESH_TOKEN_SECRET="SEU_OUTRO_SEGREDO_MAIS_SECRETO_AINDA_AQUI"

# Domínios permitidos para o CORS (separados por vírgula)
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"

# Porta em que o servidor irá rodar
PORT=3000
