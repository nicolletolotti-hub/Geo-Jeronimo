# ─── Banco de dados ────────────────────────────────────────────────────────────
# Railway provisiona automaticamente. Copie o valor de DATABASE_URL do painel.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Autenticação ───────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua_chave_secreta_muito_longa_e_aleatoria

# ─── Admin inicial ──────────────────────────────────────────────────────────────
# Criado automaticamente na primeira inicialização
ADMIN_CPF=00000000000
ADMIN_EMAIL=admin@geojeronimo.app
ADMIN_PASSWORD=senha_forte_aqui

# ─── Servidor ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS ───────────────────────────────────────────────────────────────────────
# URLs do frontend separadas por vírgula
CORS_ORIGIN=https://seu-frontend.vercel.app

# ─── Cron jobs ──────────────────────────────────────────────────────────────────
# "true" habilita o check automático de alertas a cada 15 min
ENABLE_CRON=true
