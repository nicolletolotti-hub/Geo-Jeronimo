{
  "name": "geojeronimo-backend",
  "version": "2.0.0",
  "description": "Backend for GeoJeronimo flood monitoring system",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate:create": "node-pg-migrate create -- -m src/migrations",
    "migrate": "node-pg-migrate up -m src/migrations -d DATABASE_URL",
    "deploy": "npm run migrate && npm run start",
    "seed": "node src/database/seed.js"
  },
  "keywords": [
    "gis",
    "flood",
    "monitoring",
    "express",
    "node"
  ],
  "author": "GeoJeronimo Team",
  "license": "ISC",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "node-pg-migrate": "^8.0.0",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
